using BepInEx;
using BepInEx.Logging;
using UnityEngine;

namespace GrabEx.Utilla
{
    [BepInPlugin(PluginGuid, PluginName, PluginVersion)]
    public class GrabExUtilla : BaseUnityPlugin
    {
        public const string PluginGuid = "com.grabex.utilla";
        public const string PluginName = "GrabEx Utilla";
        public const string PluginVersion = "1.2.0";

        internal static ManualLogSource Log { get; private set; }
        internal static GrabExUtilla Instance { get; private set; }

        private bool _initialized;

        private void Awake()
        {
            Instance = this;
            Log = Logger;

            Log.LogInfo($"{PluginName} v{PluginVersion} loading...");
            DontDestroyOnLoad(gameObject);
        }

        private void Start()
        {
            Initialize();
        }

        private void Initialize()
        {
            if (_initialized) return;

            _initialized = true;
            UtillaAPI.Internal_SetReady(true);

            Log.LogInfo("Framework initialized.");
            GameEvents.RaiseFrameworkLoaded();
        }
    }
}
